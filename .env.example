# Copy to .env and fill in values. Never commit .env to git.

# Required for offline preprocessing only (parse_jd.py, label_archetypes.py).
# NOT used during rank.py execution.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional model overrides (defaults: gemini-3.5-flash / gemini-2.5-pro)
# REDROB_GEMINI_FLASH_MODEL=gemini-3.5-flash
# REDROB_GEMINI_PRO_MODEL=gemini-2.5-pro

# After one successful preprocess, set to 1 to never spend Gemini credits again:
# REDROB_SKIP_GEMINI=1

# REDROB_CANDIDATES_PATH=./challenge/candidates.jsonl
# REDROB_LOG_LEVEL=INFO
